const ENTITY_META_ = { department:{sheet:'Departments',plural:'Departments'}, status:{sheet:'Statuses',plural:'Statuses'}, tag:{sheet:'Tags',plural:'Tags'} };
function saveEntity_(entity,data) { return withLock_(()=>{ const meta=ENTITY_META_[entity]; if (!meta) throw new AppError_('VALIDATION_ERROR','未知的設定類型。'); const name=required_(data.name,'名稱'), items=records_(meta.sheet), existing=data.id ? items.find((item)=>item.id===data.id) : null; if (data.id && !existing) throw new AppError_('NOT_FOUND','找不到設定資料。'); if (items.some((item)=>item.name.toLowerCase()===name.toLowerCase() && item.id!==data.id)) throw new AppError_('DUPLICATE_NAME','已有相同名稱。'); const now=nowIso_(); const record=Object.assign({},existing||{},data,{id:existing?.id||uuid_(),name:name,color:String(data.color||existing?.color||'#6366f1'),sortOrder:Number(data.sortOrder||existing?.sortOrder||nextSortOrder_(meta.sheet)),createdAt:existing?.createdAt||now,updatedAt:now}); if(entity==='department') Object.assign(record,{icon:String(data.icon||existing?.icon||'◈'),description:String(data.description||existing?.description||''),isDeleted:false}); if(entity==='status') record.isActive=asBoolean_(data.isActive,existing?.isActive!==false); if(entity==='tag') record.isDeleted=false; saveRecord_(meta.sheet,record); return record; }); }
function deleteEntity_(entity,id) { return withLock_(()=>{ const meta=ENTITY_META_[entity], item=records_(meta.sheet).find((record)=>record.id===id); if(!meta || !item) throw new AppError_('NOT_FOUND','找不到設定資料。'); const employees=records_('AI_Employees').filter((employee)=>!employee.isDeleted); const used=entity==='department' ? employees.some((e)=>e.departmentIds.includes(id)) : entity==='status' ? employees.some((e)=>e.statusId===id) : employees.some((e)=>e.tagIds.includes(id)); if(used) throw new AppError_('IN_USE','此資料仍被 AI 員工使用，請先移除關聯後再刪除。'); if(entity==='status') { item.isActive=false; item.updatedAt=nowIso_(); saveRecord_(meta.sheet,item); } else { item.isDeleted=true; item.updatedAt=nowIso_(); saveRecord_(meta.sheet,item); } return item; }); }

